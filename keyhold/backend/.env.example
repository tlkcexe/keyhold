# --- Server ---
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# --- Database ---
# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_system?schema=public"

# --- JWT ---
# Generate strong random secrets, e.g. `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Cookies ---
COOKIE_SECRET=replace_with_a_long_random_cookie_secret
# "lax" is fine for same-site setups; use "none" + secure cookies for cross-site
COOKIE_SAME_SITE=lax

# --- Password reset ---
PASSWORD_RESET_TOKEN_EXPIRES_IN_MIN=30

# --- Rate limiting ---
AUTH_RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=10
